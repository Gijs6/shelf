{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}

{% block title %}Recurring todos{% endblock %}
{% block page_class %}page--todo{% endblock %}

{% block content %}
    <header class="page-header">
        <div class="page-header__heading">
            <h1 class="page-header__title">Recurring todos</h1>
        </div>
    </header>

    {% if todos %}
        <ul class="card-list">
            {% for todo in todos %}
                <li>
                    <article class="entry-card">
                        <h3 class="entry-card__title">
                            <a href="{{ url_for('todos.view_todo', todo_id=todo.id) }}"
                               class="entry-card__link">
                                <span class="entry-card__title-text">{{ todo.display_title }}</span>
                                <span class="entry-card__badges">
                                    <span class="badge{% if todo.state=='open' %} badge--open{% elif todo.state=='active' %} badge--active{% elif todo.state=='done' %} badge--done{% elif todo.state=='cancelled' %} badge--cancelled{% endif %}">{{ todo.state | replace('_', ' ') | title }}</span>
                                    {% if todo.archived %}<span class="badge">Archived</span>{% endif %}
                                    {% if not todo.visible %}<span class="badge">Hidden</span>{% endif %}
                                </span>
                            </a>
                        </h3>
                        <p class="entry-card__timestamp">{{ icon("repeat") }} Repeats every {{ todo.recur_interval }} {{ todo.recur_interval | pluralize(todo.recur_unit) }}</p>
                        {% if todo.deadline %}
                            <p class="entry-card__due">Due {{ todo.deadline | timeago }} ({{ todo.deadline | strftime("%d %b %Y, %H:%M") }})</p>
                        {% endif %}
                        {% if todo.notify_before_days is not none %}
                            <p class="entry-card__preview">
                                {% if todo.visible %}
                                    Visible now - notifies {{ todo.notify_before_days }} {{ todo.notify_before_days | pluralize("day") }} before each deadline
                                {% else %}
                                    Hidden from lists until
                                    <time datetime="{{ todo.visible_from | isoformat }}">{{ todo.visible_from | strftime("%d %b %Y") }}</time>
                                    ({{ todo.notify_before_days }} {{ todo.notify_before_days | pluralize("day") }} before deadline)
                                {% endif %}
                            </p>
                        {% endif %}
                    </article>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        {{ empty_state('repeat', 'No recurring todos.') }}
    {% endif %}
{% endblock %}
