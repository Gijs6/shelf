{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}
{% from "partials/entry_card.jinja" import entry_card, todo_badges %}
{% from "partials/indicator.jinja" import section_indicator %}

{% block title %}Todos trash{% endblock %}
{% block page_class %}page--todo{% endblock %}

{% block content %}
    <header class="page-header page-header--todo">
        <div class="page-header__heading">
            {{ section_indicator("todo") }}
            <h1 class="page-header__title">Trash</h1>
        </div>
    </header>

    {% if todos %}
        <ul class="card-list">
            {% for todo in todos %}
                {% call entry_card(todo, timestamp=todo.deleted_at, timestamp_label="Deleted", badges=todo_badges(todo)) %}
                    <li>
                        <form hx-patch="{{ url_for('todos.restore_todo', todo_id=todo.id) }}"
                              hx-target="body"
                              hx-push-url="true">
                            <button type="submit" class="button button--ghost button--sm">{{ icon("restore") }} Restore</button>
                        </form>
                    </li>
                    <li>
                        <form hx-delete="{{ url_for('todos.purge_todo', todo_id=todo.id) }}"
                              hx-target="body"
                              hx-push-url="true"
                              hx-confirm="Permanently delete this todo? This can't be undone.">
                            <button type="submit" class="button button--danger button--sm">{{ icon("trash") }} Delete forever</button>
                        </form>
                    </li>
                {% endcall %}
            {% endfor %}
        </ul>
    {% else %}
        {{ empty_state('trash', 'Trash is empty.') }}
    {% endif %}
{% endblock %}
