{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/eyebrow.jinja" import type_eyebrow %}
{% from "partials/updated_at.jinja" import updated_at_span %}

{% block title %}{{ todo.display_title }}{% endblock %}
{% block page_class %}page--todo{% endblock %}

{% block content %}
    <article>
        <header class="page-header page-header--todo">
            <hgroup class="page-header__heading">
                {{ type_eyebrow("todo") }}
                <h1 class="page-header__title">
                    {{ todo.display_title }}
                    <span class="page-header__badges">
                        <span class="badge{% if todo.state=='open' %} badge--open{% elif todo.state=='active' %} badge--active{% elif todo.state=='done' %} badge--done{% elif todo.state=='cancelled' %} badge--cancelled{% endif %}">{{ todo.state | replace('_', ' ') | title }}</span>
                        {% if todo.overdue %}<span class="badge badge--overdue">Overdue</span>{% endif %}
                        {% if todo.archived %}<span class="badge">Archived</span>{% endif %}
                        {% if todo.recurring %}
                            <span class="badge"
                                  title="Repeats every {{ todo.recur_interval }} {{ todo.recur_interval | pluralize(todo.recur_unit) }}">{{ icon("repeat") }}</span>
                        {% endif %}
                    </span>
                </h1>
            </hgroup>
            <div class="page-header__actions">
                <a href="{{ url_for('todos.edit_todo', todo_id=todo.id) }}"
                   class="button button--ghost"
                   data-shortcut="edit">{{ icon("edit") }} Edit</a>
                {% if todo.archived %}
                    <form class="page-header__actions-form"
                          hx-patch="{{ url_for('todos.unarchive_todo', todo_id=todo.id) }}"
                          hx-target="body"
                          hx-push-url="true"
                          data-shortcut="archive-toggle">
                        <button type="submit" class="button button--ghost">{{ icon("archive") }} Unarchive</button>
                    </form>
                {% else %}
                    <form class="page-header__actions-form"
                          hx-patch="{{ url_for('todos.archive_todo', todo_id=todo.id) }}"
                          hx-target="body"
                          hx-push-url="true"
                          data-shortcut="archive-toggle">
                        <button type="submit" class="button button--ghost">{{ icon("archive") }} Archive</button>
                    </form>
                {% endif %}
                <form class="page-header__actions-form"
                      hx-delete="{{ url_for('todos.delete_todo', todo_id=todo.id) }}"
                      hx-target="body"
                      hx-push-url="true"
                      data-shortcut="delete">
                    <button type="submit" class="button button--danger">{{ icon("trash") }} Delete</button>
                </form>
            </div>
        </header>

        <form hx-patch="{{ url_for('todos.set_state', todo_id=todo.id) }}"
              hx-target="body"
              hx-push-url="true">
            <fieldset class="state-picker">
                <legend class="visually-hidden">Change state</legend>
                {% for state in states %}
                    <button type="submit"
                            name="state"
                            value="{{ state }}"
                            data-state="{{ state }}"
                            aria-pressed="{{ 'true' if todo.state==state else 'false' }}"
                            class="button button--sm state-picker__option state-picker__option--{{ state }} {% if todo.state==state %}state-picker__option--selected{% else %}button--ghost{% endif %}">{{ state | replace('_', ' ') | title }}</button>
                {% endfor %}
            </fieldset>
        </form>

        <div class="detail-meta">
            {% if todo.group_name %}<span class="detail-meta__item">{{ icon("folder") }} {{ todo.group_name }}</span>{% endif %}
            <span class="detail-meta__item">
                Made {{ todo.created_at | strftime(local=False) }} - edited
                {{ updated_at_span(todo) }}
            </span>
            {% if todo.deadline %}
                <span class="detail-meta__item">Due {{ todo.deadline | timeago }} ({{ todo.deadline | strftime("%d %b %Y, %H:%M") }})</span>
            {% endif %}
            {% if todo.recurring %}
                <span class="detail-meta__item">{{ icon("repeat") }} Repeats every {{ todo.recur_interval }} {{ todo.recur_interval | pluralize(todo.recur_unit) }}</span>
                {% if todo.notify_before_days is not none %}<span class="detail-meta__item">{{ icon("clock") }} Notifies {{ todo.notify_before_days }} {{ todo.notify_before_days | pluralize("day") }} before deadline</span>{% endif %}
            {% endif %}
            {% if todo.state == "active" and todo.active_at %}
                <span class="detail-meta__item">
                    Active since
                    <time datetime="{{ todo.active_at | isoformat(local=False) }}" data-live>{{ todo.active_at | timeago(local=False) }}</time>
                    ({{ todo.active_at | strftime("%d %b %Y, %H:%M", local=False) }})
                </span>
            {% endif %}
            {% if todo.completed_at %}<span class="detail-meta__item">Completed {{ todo.completed_at | strftime(local=False) }}</span>{% endif %}
        </div>

        <div class="markdown">{{ todo.content | markdown(kind="todo", item_id=todo.id) }}</div>
    </article>
{% endblock %}
