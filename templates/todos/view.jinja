{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/eyebrow.jinja" import type_eyebrow %}

{% block title %}{{ todo.display_title }}{% endblock %}
{% block page_class %}page--todo{% endblock %}

{% block content %}
    <article>
        <header class="page-header">
            <hgroup class="page-header__heading">
                {{ type_eyebrow("todo") }}
                <h1 class="page-header__title">
                    {{ todo.display_title }}
                    <span class="badge{% if todo.state=='open' %} badge--open{% elif todo.state=='active' %} badge--active{% elif todo.state=='done' %} badge--done{% elif todo.state=='cancelled' %} badge--cancelled{% endif %}">{{ todo.state | replace('_', ' ') | title }}</span>
                    {% if todo.overdue %}<span class="badge badge--overdue">Overdue</span>{% endif %}
                </h1>
            </hgroup>
            <div class="page-header__actions">
                <a href="{{ url_for('todos.edit_todo', todo_id=todo.id) }}"
                   class="button button--ghost">{{ icon("edit") }} Edit</a>
                {% if todo.archived %}
                    <form hx-patch="{{ url_for('todos.unarchive_todo', todo_id=todo.id) }}"
                          hx-target="body"
                          hx-push-url="true">
                        <button type="submit" class="button button--ghost">{{ icon("archive") }} Unarchive</button>
                    </form>
                {% else %}
                    <form hx-patch="{{ url_for('todos.archive_todo', todo_id=todo.id) }}"
                          hx-target="body"
                          hx-push-url="true">
                        <button type="submit" class="button button--ghost">{{ icon("archive") }} Archive</button>
                    </form>
                {% endif %}
                <form hx-delete="{{ url_for('todos.delete_todo', todo_id=todo.id) }}"
                      hx-target="body"
                      hx-push-url="true"
                      hx-confirm="Move this todo to trash?">
                    <button type="submit" class="button button--danger">{{ icon("trash") }} Delete</button>
                </form>
            </div>
        </header>

        <form hx-patch="{{ url_for('todos.set_state', todo_id=todo.id) }}"
              hx-target="body"
              hx-push-url="true">
            <fieldset class="state-picker">
                <legend class="visually-hidden">Change state</legend>
                {% for state in states %}
                    <button type="submit"
                            name="state"
                            value="{{ state }}"
                            data-state="{{ state }}"
                            class="button button--sm {% if todo.state==state %}button--active{% else %}button--ghost{% endif %}">{{ state | replace('_', ' ') | title }}</button>
                {% endfor %}
            </fieldset>
        </form>

        <div class="detail-meta">
            {% if todo.group_name %}<span class="detail-meta__group">{{ icon("folder") }} {{ todo.group_name }}</span>{% endif %}
            {% if todo.deadline %}
                <span class="detail-meta__item">Due {{ todo.deadline | timeago }} ({{ todo.deadline | strftime("%d %b %Y, %H:%M") }})</span>
            {% endif %}
            {% if todo.state == "active" and todo.active_at %}
                <span class="detail-meta__item">
                    Active since
                    <time datetime="{{ todo.active_at.isoformat() }}" data-live>{{ todo.active_at | timeago }}</time>
                    ({{ todo.active_at | strftime("%d %b %Y, %H:%M") }})
                </span>
            {% endif %}
            {% if todo.completed_at %}<span class="detail-meta__item">Completed {{ todo.completed_at | strftime }}</span>{% endif %}
        </div>

        <div class="markdown">{{ todo.content | markdown }}</div>
    </article>
{% endblock %}
