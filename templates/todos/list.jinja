{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}

{% block title %}Todos{% endblock %}
{% block page_class %}page--todo{% endblock %}

{% block content %}
    <header class="page-header">
        <div class="page-header__heading">
            <h1 class="page-header__title">Todos</h1>
        </div>
        <nav class="page-header__actions" aria-label="Todo actions">
            <a href="{{ url_for('todos.archived') }}"
               class="button button--ghost button--sm"
               aria-label="Archived todos">{{ icon("archive") }}</a>
            <a href="{{ url_for('todos.trash') }}"
               class="button button--ghost button--sm"
               aria-label="Trash">{{ icon("trash") }}</a>
            <a href="{{ url_for('todos.new_todo') }}" class="button">{{ icon("plus") }} New</a>
        </nav>
    </header>

    <form method="get" class="filters">
        <label for="state" class="visually-hidden">Filter by state</label>
        <select name="state"
                id="state"
                class="filters__select"
                onchange="this.form.submit()">
            <option value="">All states</option>
            {% for state in states %}
                <option value="{{ state }}" {% if active_state==state %}selected{% endif %}>{{ state | replace('_', ' ') | title }}</option>
            {% endfor %}
        </select>
    </form>

    {% if sections %}
        {% for label, items in sections %}
            <h2 class="list-section__title">{{ label }}</h2>
            <ul class="card-list">
                {% for todo in items %}
                    <li>
                        <article class="entry-card">
                            <h3 class="entry-card__title">
                                <a href="{{ url_for('todos.view_todo', todo_id=todo.id) }}"
                                   class="entry-card__link">
                                    <span class="entry-card__title-text">{{ todo.display_title }}</span>
                                    <span class="badge{% if todo.state=='open' %} badge--open{% elif todo.state=='active' %} badge--active{% elif todo.state=='done' %} badge--done{% elif todo.state=='cancelled' %} badge--cancelled{% endif %}">{{ todo.state | replace('_', ' ') | title }}</span>
                                    {% if todo.overdue %}<span class="badge badge--overdue">Overdue</span>{% endif %}
                                </a>
                            </h3>
                            <p class="entry-card__timestamp">
                                <time datetime="{{ todo.updated_at.isoformat() }}" data-live>{{ todo.updated_at | timeago }}</time>
                                ({{ todo.updated_at | strftime("%d %b %Y, %H:%M") }})
                            </p>
                            {% if todo.title %}<p class="entry-card__preview">{{ todo.snippet }}</p>{% endif %}
                            {% if todo.deadline %}
                                <p class="entry-card__due">Due {{ todo.deadline | timeago }} ({{ todo.deadline | strftime("%d %b %Y, %H:%M") }})</p>
                            {% endif %}
                        </article>
                    </li>
                {% endfor %}
            </ul>
        {% endfor %}
    {% else %}
        {{ empty_state("todo", "No todos yet.", url_for('todos.new_todo') , "New todo") }}
    {% endif %}
{% endblock %}
