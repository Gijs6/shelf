{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}
{% from "partials/entry_card.jinja" import entry_card, todo_badges %}

{% block title %}Todos{% endblock %}
{% block page_class %}page--todo{% endblock %}

{% block content %}
    <header class="page-header page-header--todo">
        <div class="page-header__heading">
            <h1 class="page-header__title">Todos</h1>
        </div>
        <nav class="page-header__actions" aria-label="Todo actions">
            <a href="{{ url_for('todos.archived') }}"
               class="button button--ghost button--sm button--icon-only"
               aria-label="Archived todos"
               data-shortcut="archived">{{ icon("archive") }}</a>
            <a href="{{ url_for('todos.trash') }}"
               class="button button--ghost button--sm button--icon-only"
               aria-label="Trash"
               data-shortcut="trash">{{ icon("trash") }}</a>
            <a href="{{ url_for('todos.new_todo') }}"
               class="button"
               data-shortcut="new">{{ icon("plus") }} New</a>
        </nav>
    </header>

    <nav class="filters" aria-label="Filter todos by state">
        {% for state in states %}
            <a href="{{ chip_links[state] }}"
               class="filters__chip filters__chip--{{ state }} {% if state in selected_states %}filters__chip--selected{% endif %}"
               {% if state in selected_states %}aria-current="true"{% endif %}>{{ state | replace('_', ' ') | title }}</a>
        {% endfor %}
    </nav>

    {% if sections %}
        {% for label, items in sections %}
            <section class="list-section">
                <h2 class="list-section__title">{{ label }}</h2>
                <ul class="card-list">
                    {% for todo in items %}{{ entry_card(todo, url=url_for('todos.view_todo', todo_id=todo.id) , heading_level=3, badges=todo_badges(todo)) }}{% endfor %}
                </ul>
            </section>
        {% endfor %}
    {% else %}
        {{ empty_state("todo", "No todos yet.", url_for('todos.new_todo') , "New todo") }}
    {% endif %}
{% endblock %}
