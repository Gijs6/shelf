{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}

{% block title %}Todos{% endblock %}
{% block page_class %}page--todo{% endblock %}

{% block content %}
    <header class="page-header page-header--todo">
        <div class="page-header__heading">
            <h1 class="page-header__title">Todos</h1>
        </div>
        <nav class="page-header__actions" aria-label="Todo actions">
            <a href="{{ url_for('todos.recurring') }}"
               class="button button--ghost button--sm button--icon-only"
               aria-label="Recurring todos"
               data-shortcut="recurring">{{ icon("repeat") }}</a>
            <a href="{{ url_for('todos.archived') }}"
               class="button button--ghost button--sm button--icon-only"
               aria-label="Archived todos"
               data-shortcut="archived">{{ icon("archive") }}</a>
            <a href="{{ url_for('todos.trash') }}"
               class="button button--ghost button--sm button--icon-only"
               aria-label="Trash"
               data-shortcut="trash">{{ icon("trash") }}</a>
            <a href="{{ url_for('todos.new_todo') }}"
               class="button"
               data-shortcut="new">{{ icon("plus") }} New</a>
        </nav>
    </header>

    <nav class="filters" aria-label="Filter todos by state">
        {% for state in states %}
            <a href="{{ chip_links[state] }}"
               class="filters__chip filters__chip--{{ state }} {% if state in selected_states %}filters__chip--selected{% endif %}"
               {% if state in selected_states %}aria-current="true"{% endif %}>{{ state | replace('_', ' ') | title }}</a>
        {% endfor %}
    </nav>

    {% if sections %}
        {% for label, items in sections %}
            <section class="list-section">
                <h2 class="list-section__title">{{ label }}</h2>
                <ul class="card-list">
                    {% for todo in items %}
                        <li>
                            <article class="entry-card">
                                <h3 class="entry-card__title">
                                    <a href="{{ url_for('todos.view_todo', todo_id=todo.id) }}"
                                       class="entry-card__link">
                                        <span class="entry-card__title-text">{{ todo.display_title }}</span>
                                        <span class="entry-card__badges">
                                            <span class="badge{% if todo.state=='open' %} badge--open{% elif todo.state=='active' %} badge--active{% elif todo.state=='done' %} badge--done{% elif todo.state=='cancelled' %} badge--cancelled{% endif %}">{{ todo.state | replace('_', ' ') | title }}</span>
                                            {% if todo.overdue %}<span class="badge badge--overdue">Overdue</span>{% endif %}
                                            {% if todo.recurring %}
                                                <span class="badge"
                                                      title="Repeats every {{ todo.recur_interval }} {{ todo.recur_interval | pluralize(todo.recur_unit) }}">{{ icon("repeat") }}</span>
                                            {% endif %}
                                        </span>
                                    </a>
                                </h3>
                                <p class="entry-card__timestamp">
                                    <time datetime="{{ todo.updated_at | isoformat(local=False) }}" data-live>{{ todo.updated_at | timeago(local=False) }}</time>
                                    (<time datetime="{{ todo.updated_at | isoformat(local=False) }}">{{ todo.updated_at | strftime("%d %b %Y, %H:%M", local=False) }}</time>)
                                </p>
                                {% if todo.title %}<p class="entry-card__preview">{{ todo.snippet }}</p>{% endif %}
                                {% if todo.deadline %}
                                    <p class="entry-card__due">
                                        Due <time datetime="{{ todo.deadline | isoformat }}">{{ todo.deadline | timeago }}</time>
                                        (<time datetime="{{ todo.deadline | isoformat }}">{{ todo.deadline | strftime("%d %b %Y, %H:%M") }}</time>)
                                    </p>
                                {% endif %}
                            </article>
                        </li>
                    {% endfor %}
                </ul>
            </section>
        {% endfor %}
    {% else %}
        {{ empty_state("todo", "No todos yet.", url_for('todos.new_todo') , "New todo") }}
    {% endif %}
{% endblock %}
