{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}

{% block title %}Archived todos{% endblock %}
{% block page_class %}page--todo{% endblock %}

{% block content %}
    <header class="page-header">
        <div class="page-header__heading">
            <h1 class="page-header__title">Archived todos</h1>
        </div>
    </header>

    {% if todos %}
        <ul class="card-list">
            {% for todo in todos %}
                <li>
                    <article class="entry-card">
                        <h3 class="entry-card__title">
                            <a href="{{ url_for('todos.view_todo', todo_id=todo.id) }}"
                               class="entry-card__link">
                                <span class="entry-card__title-text">{{ todo.display_title }}</span>
                            </a>
                        </h3>
                        <p class="entry-card__timestamp">
                            Archived
                            <time datetime="{{ todo.archived_at.isoformat() }}" data-live>{{ todo.archived_at | timeago }}</time>
                            ({{ todo.archived_at | strftime("%d %b %Y, %H:%M") }})
                        </p>
                        <footer class="entry-card__meta">
                            <form hx-patch="{{ url_for('todos.unarchive_todo', todo_id=todo.id) }}"
                                  hx-target="body"
                                  hx-push-url="true">
                                <button type="submit" class="button button--ghost button--sm">{{ icon("archive") }} Unarchive</button>
                            </form>
                        </footer>
                    </article>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        {{ empty_state('archive', 'No archived todos.') }}
    {% endif %}
{% endblock %}
