{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}
{% from "partials/entry_card.jinja" import entry_card, todo_badges %}
{% from "partials/indicator.jinja" import section_indicator %}

{% block title %}Archived todos{% endblock %}
{% block page_class %}page--todo{% endblock %}

{% block content %}
    <header class="page-header page-header--todo">
        <div class="page-header__heading">
            {{ section_indicator("todo") }}
            <h1 class="page-header__title">Archived</h1>
        </div>
    </header>

    {% if todos %}
        <ul class="card-list">
            {% for todo in todos %}
                {% call entry_card(todo, url=url_for('todos.view_todo', todo_id=todo.id) , timestamp=todo.archived_at, timestamp_label="Archived", badges=todo_badges(todo)) %}
                    <li>
                        <form hx-patch="{{ url_for('todos.unarchive_todo', todo_id=todo.id) }}"
                              hx-target="body"
                              hx-push-url="true">
                            <button type="submit" class="button button--ghost button--sm">{{ icon("archive") }} Unarchive</button>
                        </form>
                    </li>
                {% endcall %}
            {% endfor %}
        </ul>
    {% else %}
        {{ empty_state('archive', 'No archived todos.') }}
    {% endif %}
{% endblock %}
