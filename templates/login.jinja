{% extends "skeleton.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/flash.jinja" import flash_messages %}

{% block title %}Sign in{% endblock %}
{% block body_class %}auth-page{% endblock %}

{% block body_content %}
    {{ flash_messages() }}

    <main class="auth-layout">
        <span class="auth-layout__brand">{{ icon("note") }} Shelf</span>

        <section class="auth-layout__panel">
            <h1 class="auth-layout__heading">{{ icon("login") }} Sign in</h1>
            <form method="post" action="{{ url_for('login_post') }}" class="form">
                <div class="field">
                    <label for="password" class="field__label">{{ icon("lock") }} Password</label>
                    <input type="password"
                           id="password"
                           name="password"
                           class="field__input"
                           required
                           autofocus
                           autocomplete="current-password" />
                </div>
                <button type="submit" class="button button--block">{{ icon("login") }} Sign in</button>
            </form>
        </section>

        <p class="auth-layout__footer">Shelf</p>
    </main>
{% endblock %}
