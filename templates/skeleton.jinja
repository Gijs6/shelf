{% from "partials/icons.jinja" import icon -%}
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{%- block title -%}{%- endblock %} - Shelf</title>

        <link rel="icon" href="{{ url_for('static', filename='favicon.png') }}" />
        <link rel="manifest" href="{{ url_for('static', filename='manifest.json') }}" />
        <meta name="theme-color" content="#0a0a0d" />

        <meta name="htmx-config"
              content='{"historyCacheSize": 0, "responseHandling": [{"code": "204", "swap": false}, {"code": "[23]..", "swap": true}, {"code": "[45]..", "swap": true, "error": true}]}' />

        {% if config.DEBUG %}
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/skeleton.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/fonts.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/colors.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/theming.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/code.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/base.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/auth.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/error.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/dashboard.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/settings.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/sticky-notes.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/todos.css') }}" />
        {% else %}
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/main.min.css') }}" />
        {% endif %}

        <script src="{{ url_for('static', filename='vendor/htmx.min.js') }}" defer></script>

        {% block extra_headers %}{% endblock %}
    </head>

    <body class="{% block body_class %}{% endblock %}" hx-boost="true">
        {% block body_content %}{% endblock %}

        <dialog id="shortcuts-modal" class="modal">
            <div class="modal__header">
                <h2 class="modal__title">Keyboard shortcuts</h2>
                <form method="dialog">
                    <button type="submit" class="modal__close" aria-label="Close">{{ icon("x") }}</button>
                </form>
            </div>

            <div class="modal__group">
                <h3 class="modal__group-title">Global</h3>
                <dl class="modal__list">
                    <div class="modal__row">
                        <dt class="modal__row-term">Show this help</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">?</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Go back / close</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">Esc</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Submit the current form</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">Ctrl</kbd><kbd class="modal__key">Enter</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="modal__group">
                <h3 class="modal__group-title">Go to</h3>
                <dl class="modal__list">
                    <div class="modal__row">
                        <dt class="modal__row-term">Search</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">/</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Dashboard</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">g</kbd><kbd class="modal__key">d</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Notes</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">g</kbd><kbd class="modal__key">n</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Todos</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">g</kbd><kbd class="modal__key">t</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Sticky notes</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">g</kbd><kbd class="modal__key">s</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="modal__group">
                <h3 class="modal__group-title">Create</h3>
                <dl class="modal__list">
                    <div class="modal__row">
                        <dt class="modal__row-term">New note</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">c</kbd><kbd class="modal__key">n</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">New todo</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">c</kbd><kbd class="modal__key">t</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">New sticky note</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">c</kbd><kbd class="modal__key">s</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="modal__group">
                <h3 class="modal__group-title">On a notes/todos/sticky notes list</h3>
                <dl class="modal__list">
                    <div class="modal__row">
                        <dt class="modal__row-term">New</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">n</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Archived (Expired for sticky notes)</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">a</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Trash</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">t</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Recurring (todos only)</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">r</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="modal__group">
                <h3 class="modal__group-title">On a note or todo</h3>
                <dl class="modal__list">
                    <div class="modal__row">
                        <dt class="modal__row-term">Edit</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">e</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Toggle archive</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">a</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Trash</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">d</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Set state to open / active / done / cancelled</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">1</kbd><kbd class="modal__key">2</kbd><kbd class="modal__key">3</kbd><kbd class="modal__key">4</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="modal__group">
                <h3 class="modal__group-title">On a focused sticky note</h3>
                <dl class="modal__list">
                    <div class="modal__row">
                        <dt class="modal__row-term">Toggle pin</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">p</kbd>
                        </dd>
                    </div>
                    <div class="modal__row">
                        <dt class="modal__row-term">Trash</dt>
                        <dd class="modal__row-desc">
                            <kbd class="modal__key">d</kbd>
                        </dd>
                    </div>
                </dl>
            </div>
        </dialog>

        <script type="application/json" id="nav-routes">
            {
                "dashboard": "{{ url_for('index') }}",
                "notes": "{{ url_for('notes.list_notes') }}",
                "todos": "{{ url_for('todos.list_todos') }}",
                "stickyNotes": "{{ url_for('sticky_notes.list_sticky_notes') }}",
                "newNote": "{{ url_for('notes.new_note') }}",
                "newTodo": "{{ url_for('todos.new_todo') }}",
                "newStickyNote": "{{ url_for('sticky_notes.new_sticky_note') }}",
                "search": "{{ url_for('search.search_view') }}"
            }
        </script>

        <script src="{{ url_for('static', filename='scripts/live-timestamps.js') }}"></script>
        <script src="{{ url_for('static', filename='scripts/required-fields.js') }}"></script>
        <script src="{{ url_for('static', filename='scripts/shortcuts-modal.js') }}"></script>
        <script src="{{ url_for('static', filename='scripts/keyboard-shortcuts.js') }}"></script>
        <script src="{{ url_for('static', filename='scripts/copy-button.js') }}"></script>
        <script src="{{ url_for('static', filename='scripts/search-help-modal.js') }}"></script>
    </body>
</html>
