{% from "partials/icons.jinja" import icon -%}
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{%- block title -%}{%- endblock %} - Shelf</title>

        <link rel="icon" href="{{ url_for('static', filename='favicon.png') }}" />

        <meta name="htmx-config"
              content='{"historyCacheSize": 0, "responseHandling": [{"code": "204", "swap": false}, {"code": "[23]..", "swap": true}, {"code": "[45]..", "swap": true, "error": true}]}' />

        {% if config.DEBUG %}
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/skeleton.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/fonts.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/colors.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/theming.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/base.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/auth.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/sticky-notes.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/todos.css') }}" />
        {% else %}
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/main.min.css') }}" />
        {% endif %}

        <script src="{{ url_for('static', filename='vendor/htmx.min.js') }}" defer></script>

        {% block extra_headers %}{% endblock %}
    </head>

    <body class="{% block body_class %}{% endblock %}" hx-boost="true">
        {% block body_content %}{% endblock %}

        <dialog id="shortcuts-modal" class="shortcuts-modal">
            <div class="shortcuts-modal__header">
                <h2 class="shortcuts-modal__title">Keyboard shortcuts</h2>
                <form method="dialog">
                    <button type="submit" class="shortcuts-modal__close" aria-label="Close">{{ icon("x") }}</button>
                </form>
            </div>

            <div class="shortcuts-modal__group">
                <h3 class="shortcuts-modal__group-title">Global</h3>
                <dl class="shortcuts-modal__list">
                    <div class="shortcuts-modal__row">
                        <dt>Show this help</dt>
                        <dd>
                            <kbd>?</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Go back / close</dt>
                        <dd>
                            <kbd>Esc</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Submit the current form</dt>
                        <dd>
                            <kbd>Ctrl</kbd><kbd>Enter</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="shortcuts-modal__group">
                <h3 class="shortcuts-modal__group-title">Go to</h3>
                <dl class="shortcuts-modal__list">
                    <div class="shortcuts-modal__row">
                        <dt>Search</dt>
                        <dd>
                            <kbd>/</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Dashboard</dt>
                        <dd>
                            <kbd>g</kbd><kbd>d</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Notes</dt>
                        <dd>
                            <kbd>g</kbd><kbd>n</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Todos</dt>
                        <dd>
                            <kbd>g</kbd><kbd>t</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Sticky notes</dt>
                        <dd>
                            <kbd>g</kbd><kbd>s</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="shortcuts-modal__group">
                <h3 class="shortcuts-modal__group-title">Create</h3>
                <dl class="shortcuts-modal__list">
                    <div class="shortcuts-modal__row">
                        <dt>New note</dt>
                        <dd>
                            <kbd>c</kbd><kbd>n</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>New todo</dt>
                        <dd>
                            <kbd>c</kbd><kbd>t</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>New sticky note</dt>
                        <dd>
                            <kbd>c</kbd><kbd>s</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="shortcuts-modal__group">
                <h3 class="shortcuts-modal__group-title">On a notes/todos/sticky notes list</h3>
                <dl class="shortcuts-modal__list">
                    <div class="shortcuts-modal__row">
                        <dt>New</dt>
                        <dd>
                            <kbd>n</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Archived (Expired for sticky notes)</dt>
                        <dd>
                            <kbd>a</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Trash</dt>
                        <dd>
                            <kbd>t</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Recurring (todos only)</dt>
                        <dd>
                            <kbd>r</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="shortcuts-modal__group">
                <h3 class="shortcuts-modal__group-title">On a note or todo</h3>
                <dl class="shortcuts-modal__list">
                    <div class="shortcuts-modal__row">
                        <dt>Edit</dt>
                        <dd>
                            <kbd>e</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Toggle archive</dt>
                        <dd>
                            <kbd>a</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Trash</dt>
                        <dd>
                            <kbd>d</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Set state to open / active / done / cancelled</dt>
                        <dd>
                            <kbd>1</kbd><kbd>2</kbd><kbd>3</kbd><kbd>4</kbd>
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="shortcuts-modal__group">
                <h3 class="shortcuts-modal__group-title">On a focused sticky note</h3>
                <dl class="shortcuts-modal__list">
                    <div class="shortcuts-modal__row">
                        <dt>Toggle pin</dt>
                        <dd>
                            <kbd>p</kbd>
                        </dd>
                    </div>
                    <div class="shortcuts-modal__row">
                        <dt>Trash</dt>
                        <dd>
                            <kbd>d</kbd>
                        </dd>
                    </div>
                </dl>
            </div>
        </dialog>

        <script type="application/json" id="nav-routes">
            {
                "dashboard": "{{ url_for('index') }}",
                "notes": "{{ url_for('notes.list_notes') }}",
                "todos": "{{ url_for('todos.list_todos') }}",
                "stickyNotes": "{{ url_for('sticky_notes.list_sticky_notes') }}",
                "newNote": "{{ url_for('notes.new_note') }}",
                "newTodo": "{{ url_for('todos.new_todo') }}",
                "newStickyNote": "{{ url_for('sticky_notes.new_sticky_note') }}",
                "search": "{{ url_for('search.search_view') }}"
            }
        </script>

        <script src="{{ url_for('static', filename='scripts/live-timestamps.js') }}"></script>
        <script src="{{ url_for('static', filename='scripts/required-fields.js') }}"></script>
        <script src="{{ url_for('static', filename='scripts/shortcuts-modal.js') }}"></script>
        <script src="{{ url_for('static', filename='scripts/keyboard-shortcuts.js') }}"></script>
        <script src="{{ url_for('static', filename='scripts/copy-button.js') }}"></script>
    </body>
</html>
