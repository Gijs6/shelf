{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}

{% block title %}Settings{% endblock %}

{% block content %}
    <header class="page-header">
        <div class="page-header__heading">
            <h1 class="page-header__title">{{ icon("settings") }} Settings</h1>
        </div>
    </header>

    <div class="settings-grid">

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("download") }} Export</h2>
            <p class="settings-panel__desc">Download all notes, sticky notes, and todos as a single JSON file.</p>
            <a href="{{ url_for('settings.export') }}" class="button">{{ icon("download") }} Export JSON</a>
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("upload") }} Import</h2>
            <p class="settings-panel__desc">Restore or merge data from a previously exported JSON file. Records whose ID matches an existing one are updated in place, everything else is added.</p>
            <form method="post"
                  action="{{ url_for('settings.import_data') }}"
                  enctype="multipart/form-data"
                  class="form">
                <div class="field">
                    <label for="file" class="field__label">JSON file</label>
                    <input type="file"
                           id="file"
                           name="file"
                           class="field__input"
                           accept="application/json,.json"
                           required />
                </div>
                <button type="submit" class="button">{{ icon("upload") }} Import</button>
            </form>
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("trash") }} Remove all</h2>
            <p class="settings-panel__desc">Permanently delete every note, sticky note, and todo. Export a backup first if you might need this data again.</p>
            <form hx-delete="{{ url_for('settings.remove_all') }}"
                  hx-target="body"
                  hx-push-url="true"
                  hx-confirm="Are you really sure to PERMANENTLY delete ALL notes, todos and sticky notes? THIS CANNOT BE UNDONE.">
                <button type="submit" class="button button--danger">{{ icon("trash") }} Remove all data</button>
            </form>
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("logout") }} Log out</h2>
            <p class="settings-panel__desc">End your current session.</p>
            <form method="post" action="{{ url_for('logout') }}">
                <button type="submit" class="button">{{ icon("logout") }} Log out</button>
            </form>
        </section>
    </div>

{% endblock %}
