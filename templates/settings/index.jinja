{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}

{% block title %}Settings{% endblock %}

{% block content %}
    <header class="page-header">
        <div class="page-header__heading">
            <h1 class="page-header__title">{{ icon("settings") }} Settings</h1>
        </div>
    </header>

    <div class="settings-grid">

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("download") }} Export all data</h2>
            <a href="{{ url_for('settings.export') }}" class="button">{{ icon("download") }} Export JSON</a>
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("upload") }} Import data</h2>
            <form method="post"
                  action="{{ url_for('settings.import_data') }}"
                  enctype="multipart/form-data"
                  class="form">
                <div class="field">
                    <label for="file" class="field__label">JSON file</label>
                    <input type="file"
                           id="file"
                           name="file"
                           class="field__input"
                           accept="application/json,.json"
                           required />
                </div>
                <button type="submit" class="button">{{ icon("upload") }} Import</button>
            </form>
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("database") }} Purge trash</h2>
            {% if total_trash %}
                <p>
                    {{ trash_counts.notes }} {{ trash_counts.notes | pluralize("note") }},
                    {{ trash_counts.sticky_notes }} sticky {{ trash_counts.sticky_notes | pluralize("note") }},
                    {{ trash_counts.todos }} {{ trash_counts.todos | pluralize("todo") }} in trash.
                </p>
                <form hx-delete="{{ url_for('settings.purge_all_trash') }}"
                      hx-target="body"
                      hx-push-url="true"
                      hx-confirm="Permanently delete everything in trash across notes, todos and sticky notes? THIS CANNOT BE UNDONE.">
                    <button type="submit" class="button button--danger">{{ icon("trash") }} Purge all trash</button>
                </form>
            {% else %}
                <p>Trash is empty.</p>
            {% endif %}
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("sticky") }} Expired sticky notes</h2>
            {% if expired_sticky_note_count %}
                <p>
                    {{ expired_sticky_note_count }} expired sticky
                    {{ expired_sticky_note_count | pluralize("note") }} not yet in trash.
                </p>
                <form hx-delete="{{ url_for('settings.clear_expired_sticky_notes') }}"
                      hx-target="body"
                      hx-push-url="true"
                      hx-confirm="Move all expired sticky notes to trash?">
                    <button type="submit" class="button button--danger">{{ icon("trash") }} Clear expired</button>
                </form>
            {% else %}
                <p>No expired sticky notes.</p>
            {% endif %}
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("folder") }} Groups</h2>
            {% if group_counts %}
                <ul class="settings-list">
                    {% for name, counts in group_counts.items() %}
                        <li class="settings-list__item">
                            <span class="settings-list__name">{{ name }}</span>
                            <span class="settings-list__meta">
                                {{ counts.notes }} {{ counts.notes | pluralize("note") }},
                                {{ counts.todos }} {{ counts.todos | pluralize("todo") }}
                            </span>
                            <button type="button"
                                    class="button button--ghost button--sm"
                                    data-rename-group="{{ name }}"
                                    aria-haspopup="dialog">{{ icon("edit") }} Rename</button>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p>No groups in use yet.</p>
            {% endif %}
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("trash") }} Remove all data</h2>
            <form hx-delete="{{ url_for('settings.remove_all') }}"
                  hx-target="body"
                  hx-push-url="true"
                  hx-confirm="Are you really sure to PERMANENTLY delete ALL notes, todos and sticky notes? THIS CANNOT BE UNDONE.">
                <button type="submit" class="button button--danger">{{ icon("trash") }} Remove all data</button>
            </form>
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("calendar") }} Calendar feed</h2>
            {% if calendar_url %}
                <p>Subscribe to this URL from your favourite calendar app to see todo deadlines.</p>
                <div class="field">
                    <label for="calendar-url" class="field__label">Feed URL</label>
                    <input type="text"
                           id="calendar-url"
                           class="field__input"
                           value="{{ calendar_url }}"
                           readonly />
                </div>
                <menu class="settings-panel__actions">
                    <li>
                        <button type="button"
                                class="button button--ghost"
                                data-copy-target="calendar-url">{{ icon("copy") }} Copy</button>
                    </li>
                    <li>
                        <form hx-post="{{ url_for('settings.generate_calendar_token') }}"
                              hx-target="body"
                              hx-push-url="true"
                              hx-confirm="Regenerate the token? The old feed URL will stop working.">
                            <button type="submit" class="button button--ghost">{{ icon("repeat") }} Regenerate</button>
                        </form>
                    </li>
                    <li>
                        <form hx-delete="{{ url_for('settings.revoke_calendar_token') }}"
                              hx-target="body"
                              hx-push-url="true">
                            <button type="submit" class="button button--danger">{{ icon("trash") }} Revoke</button>
                        </form>
                    </li>
                </menu>
            {% else %}
                <p>Generate a token to get a private URL you can subscribe to from a calendar app.</p>
                <form hx-post="{{ url_for('settings.generate_calendar_token') }}"
                      hx-target="body"
                      hx-push-url="true">
                    <button type="submit" class="button">{{ icon("calendar") }} Generate token</button>
                </form>
            {% endif %}
        </section>

        <section class="settings-panel">
            <h2 class="settings-panel__title">{{ icon("logout") }} Session</h2>
            {% if last_login %}
                <p>
                    Logged in since
                    <time datetime="{{ last_login | isoformat }}">{{ last_login | strftime("%d %b %Y, %H:%M") }}</time>
                    ({{ last_login | timeago }}).
                    <br />
                    Session expires
                    <time datetime="{{ session_expires_at | isoformat }}">{{ session_expires_at | strftime("%d %b %Y, %H:%M") }}</time>
                    ({{ session_expires_at | timeago }}).
                </p>
            {% endif %}
            <form method="post" action="{{ url_for('logout') }}">
                <button type="submit" class="button">{{ icon("logout") }} Log out</button>
            </form>
        </section>
    </div>

    <dialog id="rename-group-modal" class="modal modal--stacked">
        <header class="modal__header">
            <h2 class="modal__title">Rename group</h2>
            <form method="dialog">
                <button type="submit" class="modal__close" aria-label="Close">{{ icon("x") }}</button>
            </form>
        </header>

        <form hx-post="{{ url_for('settings.rename_group') }}"
              hx-target="body"
              hx-push-url="true">
            <input type="hidden" name="old_name" value="" />
            <div class="field">
                <label for="rename-group-name" class="field__label">New name</label>
                <input type="text"
                       id="rename-group-name"
                       name="new_name"
                       class="field__input"
                       required />
            </div>
            <button type="submit" class="button">{{ icon("edit") }} Rename</button>
        </form>
    </dialog>

{% endblock %}
