{% from "partials/icons.jinja" import icon %}

{% macro sticky_card(sticky_note, compact=False, heading_level=3, auto_open=False) %}
    <li>
        <article id="sticky-{{ sticky_note.id }}"
                 class="sticky-note sticky-note--{{ sticky_note.colour }}{% if sticky_note.pinned %} sticky-note--pinned{% endif %}{% if auto_open %} sticky-note--editing{% endif %}"
                 data-update-url="{{ url_for('sticky_notes.update_sticky_note', sticky_note_id=sticky_note.id) }}"
                 {% if auto_open %}data-autoedit{% endif %}>
            <div class="sticky-note__content">
                <div class="sticky-note__view">
                    {% if sticky_note.title %}<h {{ heading_level }} class="sticky-note__title">{{ sticky_note.title | markdown_inline(links=false) }}</h {{ heading_level }}>{% endif %}
                    <div id="sticky-body-{{ sticky_note.id }}" class="sticky-note__body">{{ sticky_note.content | markdown(kind="sticky", item_id=sticky_note.id) }}</div>
                </div>

                <form class="sticky-note__edit" novalidate>
                    <label class="visually-hidden" for="sticky-title-input-{{ sticky_note.id }}">Title</label>
                    <input type="text"
                           id="sticky-title-input-{{ sticky_note.id }}"
                           name="title"
                           class="sticky-note__title-input"
                           placeholder="Title"
                           value="{{ sticky_note.title or '' }}" />

                    <label class="visually-hidden"
                           for="sticky-content-input-{{ sticky_note.id }}">Content (markdown)</label>
                    <textarea id="sticky-content-input-{{ sticky_note.id }}"
                              name="content"
                              class="sticky-note__content-input"
                              placeholder="Write in markdown...">{{ sticky_note.content }}</textarea>

                    <div class="colour-picker colour-picker--inline"
                         role="group"
                         aria-label="Colour">
                        {% for colour in STICKY_COLOURS %}
                            <button type="button"
                                    class="colour-picker__option colour-picker__option--{{ colour }}{% if sticky_note.colour==colour %} colour-picker__option--selected{% endif %}"
                                    data-colour="{{ colour }}"
                                    aria-pressed="{{ 'true' if sticky_note.colour==colour else 'false' }}">
                                <span class="visually-hidden">{{ colour | capitalize }}</span>
                            </button>
                        {% endfor %}
                    </div>
                    <input type="hidden"
                           name="colour"
                           class="sticky-note__colour-value"
                           value="{{ sticky_note.colour }}" />

                    <label class="sticky-note__expiry-label"
                           for="sticky-expires-input-{{ sticky_note.id }}">Expires</label>
                    <input type="datetime-local"
                           id="sticky-expires-input-{{ sticky_note.id }}"
                           name="expires_at"
                           class="sticky-note__expiry-input"
                           value="{{ sticky_note.expires_at.strftime('%Y-%m-%dT%H:%M') if sticky_note.expires_at else '' }}" />

                    <input type="hidden" name="heading_level" value="{{ heading_level }}" />
                    <input type="hidden" name="compact" value="{{ '1' if compact else '' }}" />
                </form>
            </div>

            {% if not compact %}
                <menu class="sticky-note__actions">
                    <li>
                        <form hx-patch="{{ url_for('sticky_notes.toggle_pin', sticky_note_id=sticky_note.id) }}"
                              hx-target="body"
                              hx-push-url="true"
                              data-shortcut="sticky-pin">
                            <button type="submit"
                                    class="sticky-note__icon-button sticky-note__icon-button--pin">
                                <span class="visually-hidden">Toggle pin</span>
                                {{ icon("pin") }}
                            </button>
                        </form>
                    </li>
                    <li>
                        <button type="button"
                                class="sticky-note__icon-button"
                                data-copy-html-target="sticky-body-{{ sticky_note.id }}"
                                data-copy-title="{{ sticky_note.title or '' }}">
                            <span class="visually-hidden">Copy</span>
                            {{ icon("copy") }}
                        </button>
                    </li>
                    <li>
                        <form hx-delete="{{ url_for('sticky_notes.delete_sticky_note', sticky_note_id=sticky_note.id) }}"
                              hx-target="body"
                              hx-push-url="true"
                              data-shortcut="sticky-delete">
                            <button type="submit" class="sticky-note__icon-button">
                                <span class="visually-hidden">Delete</span>
                                {{ icon("trash") }}
                            </button>
                        </form>
                    </li>
                </menu>

                <footer class="sticky-note__footer">
                    {% if sticky_note.expires_at and not sticky_note.pinned %}
                        <p class="sticky-note__expires">
                            {% if sticky_note.expired %}
                                Expired
                            {% else %}
                                Expires
                            {% endif %}
                            <time datetime="{{ sticky_note.expires_at | isoformat }}">{{ sticky_note.expires_at | strftime }}</time>
                        </p>
                    {% endif %}
                    <p class="sticky-note__made">
                        Made <time datetime="{{ sticky_note.created_at | isoformat(local=False) }}"
       data-live>{{ sticky_note.created_at | timeago(local=False) }}</time>
                    </p>
                </footer>
            {% endif %}
        </article>
    </li>
{% endmacro %}
