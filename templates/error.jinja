{% extends "skeleton.jinja" %}

{% block title %}{{ code }} {{ title }}{% endblock %}

{% block body_content %}
    <main class="error-page">
        <hgroup>
            <p class="error-page__code">{{ code }}</p>
            <h1 class="error-page__title">{{ title }}</h1>
        </hgroup>
        <p class="error-page__desc">{{ description }}</p>
        <a href="{{ url_for('index') }}" class="button">Go home</a>
    </main>
{% endblock %}
