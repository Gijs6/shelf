{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}
{% from "partials/sticky_card.jinja" import sticky_card %}

{% block title %}Sticky notes{% endblock %}
{% block page_class %}page--sticky{% endblock %}

{% block content %}
    <header class="page-header page-header--sticky">
        <div class="page-header__heading">
            <h1 class="page-header__title">Sticky notes</h1>
        </div>
        <nav class="page-header__actions" aria-label="Sticky note actions">
            <a href="{{ url_for('sticky_notes.expired') }}"
               class="button button--ghost"
               data-shortcut="archived">{{ icon("archive") }} Expired</a>
            <a href="{{ url_for('sticky_notes.trash') }}"
               class="button button--ghost"
               data-shortcut="trash">{{ icon("trash") }} Trash</a>
            <a href="{{ url_for('sticky_notes.new_sticky_note') }}"
               class="button"
               data-shortcut="new">{{ icon("plus") }} New sticky note</a>
        </nav>
    </header>

    {% if pinned_notes %}
        <ul class="sticky-board sticky-board--pinned">
            {% for sticky_note in pinned_notes %}{{ sticky_card(sticky_note, heading_level=2) }}{% endfor %}
        </ul>
    {% endif %}

    {% if active_notes %}
        <ul class="sticky-board">
            {% for sticky_note in active_notes %}{{ sticky_card(sticky_note, heading_level=2) }}{% endfor %}
        </ul>
    {% elif not pinned_notes %}
        {{ empty_state("sticky", "No sticky notes yet.", url_for('sticky_notes.new_sticky_note') , "New sticky note") }}
    {% endif %}
{% endblock %}
