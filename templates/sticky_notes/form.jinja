{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}

{% block title %}
    {% if sticky_note and sticky_note.id %}
        Edit sticky note
    {% else %}
        New sticky note
    {% endif %}
{% endblock %}
{% block page_class %}page--sticky{% endblock %}

{% block content %}
    <header class="page-header page-header--sticky">
        <div class="page-header__heading">
            <h1 class="page-header__title">
                {% if sticky_note and sticky_note.id %}
                    Sticky notes > edit {{ sticky_note.id }}
                {% else %}
                    Sticky notes > new
                {% endif %}
            </h1>
        </div>
    </header>

    <form {% if sticky_note and sticky_note.id %} hx-put="{{ url_for('sticky_notes.update_sticky_note', sticky_note_id=sticky_note.id) }}" {% else %} hx-post="{{ url_for('sticky_notes.create_sticky_note') }}" {% endif %}
          hx-target="body"
          hx-push-url="true"
          class="editor"
          data-require-either="title,content">
        <div class="editor__body">
            <label for="title" class="visually-hidden">Title</label>
            <input type="text"
                   id="title"
                   name="title"
                   class="editor__title"
                   placeholder="Sticky note title"
                   value="{{ sticky_note.title or '' }}"
                   autofocus />

            <label for="content" class="visually-hidden">Content (markdown)</label>
            <textarea id="content"
                      name="content"
                      class="editor__content"
                      placeholder="Write in markdown...">{{ sticky_note.content if sticky_note else '' }}</textarea>

            <div class="editor__sidebar">
                <div class="editor__meta">
                    <fieldset class="editor__meta-group">
                        <legend class="editor__meta-title">Colour</legend>
                        <div class="colour-picker">
                            {% for colour in colours %}
                                <label class="colour-picker__option colour-picker__option--{{ colour }}">
                                    <input type="radio"
                                           name="colour"
                                           value="{{ colour }}"
                                           class="visually-hidden"
                                           {% if (sticky_note and sticky_note.colour==colour) or (not sticky_note and colour=="yellow") %}checked{% endif %} />
                                    {{ colour }}
                                </label>
                            {% endfor %}
                        </div>
                    </fieldset>

                    <fieldset class="editor__meta-group">
                        <legend class="editor__meta-title">Details</legend>
                        <div class="field editor__field">
                            <label for="expires_at" class="field__label">Expires at</label>
                            <input type="datetime-local"
                                   id="expires_at"
                                   name="expires_at"
                                   class="field__input"
                                   value="{{ sticky_note.expires_at.strftime('%Y-%m-%dT%H:%M') if sticky_note and sticky_note.expires_at else (default_expires_at.strftime('%Y-%m-%dT%H:%M') if not sticky_note else '') }}" />
                        </div>

                        <div class="field field--checkbox editor__field">
                            <label for="pinned" class="field__label">
                                <input type="checkbox"
                                       id="pinned"
                                       name="pinned"
                                       class="field__checkbox"
                                       {% if sticky_note and sticky_note.pinned %}checked{% endif %} />
                                {{ icon("pin") }} Pinned
                            </label>
                        </div>
                    </fieldset>
                </div>

                <div class="editor__actions">
                    <button type="submit" class="button">{{ icon("edit") }} Save sticky note</button>
                </div>

                {% if sticky_note and sticky_note.id %}
                    <menu class="editor__convert">
                        <li>
                            <button type="submit" form="convert-to-note" class="button button--ghost">{{ icon("repeat") }} Convert to note</button>
                        </li>
                        <li>
                            <button type="submit" form="convert-to-todo" class="button button--ghost">{{ icon("repeat") }} Convert to todo</button>
                        </li>
                    </menu>
                {% endif %}
            </div>
        </div>
    </form>

    {% if sticky_note and sticky_note.id %}
        <form id="convert-to-note"
              hx-post="{{ url_for('sticky_notes.convert_sticky_note_to_note', sticky_note_id=sticky_note.id) }}"
              hx-target="body"
              hx-push-url="true"
              hx-confirm="Convert this sticky note to a note? It will get a new URL, and you'll lose any unsaved changes made here.">
        </form>
        <form id="convert-to-todo"
              hx-post="{{ url_for('sticky_notes.convert_sticky_note_to_todo', sticky_note_id=sticky_note.id) }}"
              hx-target="body"
              hx-push-url="true"
              hx-confirm="Convert this sticky note to a todo? It will get a new URL, and you'll lose any unsaved changes made here.">
        </form>
    {% endif %}
{% endblock %}
