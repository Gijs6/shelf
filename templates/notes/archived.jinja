{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}
{% from "partials/entry_card.jinja" import entry_card %}
{% from "partials/indicator.jinja" import section_indicator %}

{% block title %}Archived notes{% endblock %}
{% block page_class %}page--note{% endblock %}

{% block content %}
    <header class="page-header page-header--note">
        <div class="page-header__heading">
            {{ section_indicator("note") }}
            <h1 class="page-header__title">Archived</h1>
        </div>
    </header>

    {% if notes %}
        <ul class="card-list">
            {% for note in notes %}
                {% call entry_card(note, url=url_for('notes.view_note', note_id=note.id) , timestamp=note.archived_at, timestamp_label="Archived") %}
                    <li>
                        <form hx-patch="{{ url_for('notes.unarchive_note', note_id=note.id) }}"
                              hx-target="body"
                              hx-push-url="true">
                            <button type="submit" class="button button--ghost button--sm">{{ icon("archive") }} Unarchive</button>
                        </form>
                    </li>
                {% endcall %}
            {% endfor %}
        </ul>
    {% else %}
        {{ empty_state('archive', 'No archived notes.') }}
    {% endif %}
{% endblock %}
