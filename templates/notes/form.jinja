{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/indicator.jinja" import section_indicator %}

{% block title %}
    {% if note and note.id %}
        Edit note
    {% else %}
        New note
    {% endif %}
{% endblock %}
{% block page_class %}page--note{% endblock %}

{% block content %}
    <header class="page-header page-header--note">
        <div class="page-header__heading">
            {{ section_indicator("note") }}
            <h1 class="page-header__title">
                {% if note and note.id %}
                    Edit {{ note.id }}
                {% else %}
                    New
                {% endif %}
            </h1>
        </div>
    </header>

    <form {% if note and note.id %} hx-put="{{ url_for('notes.update_note', note_id=note.id) }}" {% else %} hx-post="{{ url_for('notes.create_note') }}" {% endif %}
          hx-target="body"
          hx-push-url="true"
          class="editor"
          data-require-either="title,content">
        <div class="editor__body">
            <label for="title" class="visually-hidden">Title</label>
            <input type="text"
                   id="title"
                   name="title"
                   class="editor__title"
                   placeholder="Note title"
                   value="{{ note.title or '' }}"
                   autofocus />

            <label for="content" class="visually-hidden">Content (markdown)</label>
            <textarea id="content"
                      name="content"
                      class="editor__content"
                      placeholder="Write in markdown...">{{ note.content if note else '' }}</textarea>

            <div class="editor__sidebar">
                <div class="editor__meta">
                    <fieldset class="editor__meta-group">
                        <legend class="editor__meta-title">Details</legend>
                        <div class="field editor__field">
                            <label for="group" class="field__label">Group</label>
                            <input type="text"
                                   id="group"
                                   name="group"
                                   class="field__input"
                                   list="note-groups"
                                   autocomplete="off"
                                   placeholder="Search or create a group"
                                   value="{{ note.group_name or '' }}" />
                            <datalist id="note-groups">
                                {% for group in groups %}<option value="{{ group }}"></option>{% endfor %}
                            </datalist>
                        </div>
                    </fieldset>
                </div>

                <div class="editor__actions">
                    <button type="submit" class="button">{{ icon("edit") }} Save note</button>
                </div>

                {% if note and note.id %}
                    <menu class="editor__convert">
                        <li>
                            <button type="submit" form="convert-to-todo" class="button button--ghost">{{ icon("repeat") }} Convert to todo</button>
                        </li>
                        <li>
                            <button type="submit"
                                    form="convert-to-sticky-note"
                                    class="button button--ghost">{{ icon("repeat") }} Convert to sticky note</button>
                        </li>
                    </menu>
                {% endif %}
            </div>
        </div>
    </form>

    {% if note and note.id %}
        <form id="convert-to-todo"
              hx-post="{{ url_for('notes.convert_note_to_todo', note_id=note.id) }}"
              hx-target="body"
              hx-push-url="true"
              hx-confirm="Convert this note to a todo? It will get a new URL, and you'll lose any unsaved changes made here.">
        </form>
        <form id="convert-to-sticky-note"
              hx-post="{{ url_for('notes.convert_note_to_sticky_note', note_id=note.id) }}"
              hx-target="body"
              hx-push-url="true"
              hx-confirm="Convert this note to a sticky note? It will get a new URL, and you'll lose any unsaved changes made here.">
        </form>
    {% endif %}
{% endblock %}
