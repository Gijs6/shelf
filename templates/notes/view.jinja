{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/eyebrow.jinja" import type_eyebrow %}
{% from "partials/updated_at.jinja" import updated_at_span %}

{% block title %}{{ note.display_title }}{% endblock %}
{% block page_class %}page--note{% endblock %}

{% block content %}
    <article>
        <header class="page-header page-header--note">
            <hgroup class="page-header__heading">
                {{ type_eyebrow("note") }}
                <h1 class="page-header__title">
                    {{ note.display_title }}
                    {% if note.archived %}
                        <span class="page-header__badges">
                            <span class="badge">Archived</span>
                        </span>
                    {% endif %}
                </h1>
            </hgroup>
            <div class="page-header__actions">
                <a href="{{ url_for('notes.edit_note', note_id=note.id) }}"
                   class="button button--ghost"
                   data-shortcut="edit">{{ icon("edit") }} Edit</a>
                {% if note.archived %}
                    <form class="page-header__actions-form"
                          hx-patch="{{ url_for('notes.unarchive_note', note_id=note.id) }}"
                          hx-target="body"
                          hx-push-url="true"
                          data-shortcut="archive-toggle">
                        <button type="submit" class="button button--ghost">{{ icon("archive") }} Unarchive</button>
                    </form>
                {% else %}
                    <form class="page-header__actions-form"
                          hx-patch="{{ url_for('notes.archive_note', note_id=note.id) }}"
                          hx-target="body"
                          hx-push-url="true"
                          data-shortcut="archive-toggle">
                        <button type="submit" class="button button--ghost">{{ icon("archive") }} Archive</button>
                    </form>
                {% endif %}
                <form class="page-header__actions-form"
                      hx-delete="{{ url_for('notes.delete_note', note_id=note.id) }}"
                      hx-target="body"
                      hx-push-url="true"
                      data-shortcut="delete">
                    <button type="submit" class="button button--danger">{{ icon("trash") }} Delete</button>
                </form>
            </div>
        </header>

        <div class="detail-meta">
            {% if note.group_name %}
                <a class="detail-meta__item" href="{{ url_for('search.search_view', q='is:note group:' + note.group_name) }}">{{ icon("folder") }} {{ note.group_name }}</a>
            {% endif %}
            <span class="detail-meta__item">
                Made {{ note.created_at | strftime(local=False) }} - edited
                {{ updated_at_span(note) }}
            </span>
        </div>

        <div class="markdown">{{ note.content | markdown(kind="note", item_id=note.id) }}</div>
    </article>
{% endblock %}
