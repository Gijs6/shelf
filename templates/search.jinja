{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}
{% from "partials/entry_card.jinja" import entry_card, todo_badges %}

{% block title %}Search{% endblock %}

{% block content %}
    <header class="page-header">
        <div class="page-header__heading">
            <h1 class="page-header__title">Search</h1>
        </div>
        <menu class="page-header__actions">
            <li>
                <button type="button"
                        class="button button--ghost"
                        data-search-help-toggle
                        aria-haspopup="dialog">{{ icon("info") }} Search syntax</button>
            </li>
        </menu>
    </header>

    <dialog id="search-help-modal" class="modal modal--stacked">
        <header class="modal__header">
            <h2 class="modal__title">Search syntax</h2>
            <form method="dialog">
                <button type="submit" class="modal__close" aria-label="Close">{{ icon("x") }}</button>
            </form>
        </header>

        <section class="modal__group">
            <h3 class="modal__group-title">Type</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">is:note</code> <code class="modal__chip">is:todo</code> <code class="modal__chip">is:sticky</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Only that type (repeat to combine)
                    </dd>
                </div>
            </dl>
        </section>

        <section class="modal__group">
            <h3 class="modal__group-title">Todo filters</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">state:shelved|open|active|done|cancelled</code>
                    </dt>
                    <dd class="modal__row-desc">
                        By todo state
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">overdue:yes</code> / <code class="modal__chip">no</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Overdue todos
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">due:today</code> / <code class="modal__chip">due:week</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Due today / within 7 days
                    </dd>
                </div>
            </dl>
        </section>

        <section class="modal__group">
            <h3 class="modal__group-title">Sticky note filters</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">pinned:yes</code> / <code class="modal__chip">no</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Pinned sticky notes
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">colour:pink</code>
                    </dt>
                    <dd class="modal__row-desc">
                        yellow, pink, blue, green, purple, orange
                    </dd>
                </div>
            </dl>
        </section>

        <section class="modal__group">
            <h3 class="modal__group-title">Notes &amp; todos</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">group:home</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Exact group name
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">archived:yes</code> / <code class="modal__chip">no</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Archived items
                    </dd>
                </div>
            </dl>
        </section>

        <section class="modal__group">
            <h3 class="modal__group-title">Dates</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">before:2026-01-01</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Created before a date (YYYY-MM-DD, all types)
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">after:2026-01-01</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Created on/after a date (YYYY-MM-DD, all types) - for todo deadlines use <code>due:today</code> / <code>due:week</code> instead
                    </dd>
                </div>
            </dl>
        </section>

        <section class="modal__group">
            <h3 class="modal__group-title">Sorting &amp; text</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code class="modal__chip">sort:title</code> / <code class="modal__chip">sort:created</code> / <code class="modal__chip">sort:updated</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Default: last updated
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">Any other words</dt>
                    <dd class="modal__row-desc">
                        Matched against title &amp; content
                    </dd>
                </div>
            </dl>
        </section>
    </dialog>

    <search>
    <form method="get"
          class="filters"
          hx-get="{{ url_for('search.search_view') }}"
          hx-trigger="input changed from:find input, submit"
          hx-select="#search-results"
          hx-target="#search-results"
          hx-swap="outerHTML"
          hx-replace-url="true">
        <label for="q" class="visually-hidden">Search</label>
        <input type="search"
               id="q"
               name="q"
               class="field__input filters__input"
               placeholder="is:todo state:open group:home overdue:yes due:week sort:title ..."
               value="{{ query }}"
               autocomplete="off"
               autofocus />
        <button type="submit" class="button">{{ icon("search") }} Search</button>
    </form>
    </search>

    <section id="search-results" aria-label="Search results">
        {% if not query %}
            {{ empty_state('search', 'Try is:todo, is:note, is:sticky, state:open, group:home, archived:yes, pinned:yes, overdue:yes, due:today, due:week, before:2026-01-01, after:2026-01-01, sort:title, sort:created, colour:pink') }}
        {% elif results %}
            <p class="search-results__count">{{ results | length }} result{{ "s" if results | length != 1 else "" }}</p>
            <ul class="card-list">
                {% for result in results %}
                    {% set badges %}
                        <span class="badge badge--{{ result.kind }}">{{ icon(result.kind) }} {{ result.kind | capitalize }}</span>
                        {% if result.kind == "todo" %}{{ todo_badges(result) }}{% endif %}
                        {% if result.kind in ("note", "todo") and result.archived %}<span class="badge badge--neutral">{{ icon("archive") }} Archived</span>{% endif %}
                        {% if result.kind == "sticky" and result.pinned %}<span class="badge badge--neutral">{{ icon("pin") }} Pinned</span>{% endif %}
                        {% if result.get("group_name") %}<span class="badge badge--group">{{ icon("folder") }} {{ result.group_name }}</span>{% endif %}
                    {% endset %}
                    {{ entry_card(result, url=url_for(result.endpoint, **result.url_kwargs) , badges=badges) }}
                {% endfor %}
            </ul>
        {% else %}
            {{ empty_state("search", 'No results for "' + query + '".') }}
        {% endif %}
    </section>
{% endblock %}
