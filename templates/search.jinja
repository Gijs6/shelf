{% extends "base.jinja" %}

{% from "partials/icons.jinja" import icon %}
{% from "partials/empty_state.jinja" import empty_state %}

{% block title %}Search{% endblock %}

{% block content %}
    <header class="page-header">
        <div class="page-header__heading">
            <h1 class="page-header__title">{{ icon("search") }} Search</h1>
        </div>
        <div class="page-header__actions">
            <button type="button"
                    class="button button--ghost"
                    data-search-help-toggle
                    aria-haspopup="dialog">{{ icon("info") }} Search syntax</button>
        </div>
    </header>

    <dialog id="search-help-modal" class="modal">
        <div class="modal__header">
            <h2 class="modal__title">Search syntax</h2>
            <form method="dialog">
                <button type="submit" class="modal__close" aria-label="Close">{{ icon("x") }}</button>
            </form>
        </div>

        <div class="modal__group">
            <h3 class="modal__group-title">Type</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>is:note</code> <code>is:todo</code> <code>is:sticky</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Only that type (repeat to combine)
                    </dd>
                </div>
            </dl>
        </div>

        <div class="modal__group">
            <h3 class="modal__group-title">Todo filters</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>state:open|active|done|cancelled</code>
                    </dt>
                    <dd class="modal__row-desc">
                        By todo state
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>overdue:yes</code> / <code>no</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Overdue todos
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>due:today</code> / <code>due:week</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Due today / within 7 days
                    </dd>
                </div>
            </dl>
        </div>

        <div class="modal__group">
            <h3 class="modal__group-title">Sticky note filters</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>pinned:yes</code> / <code>no</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Pinned sticky notes
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>colour:pink</code>
                    </dt>
                    <dd class="modal__row-desc">
                        yellow, pink, blue, green, purple, orange
                    </dd>
                </div>
            </dl>
        </div>

        <div class="modal__group">
            <h3 class="modal__group-title">Notes &amp; todos</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>group:home</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Exact group name
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>archived:yes</code> / <code>no</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Archived items
                    </dd>
                </div>
            </dl>
        </div>

        <div class="modal__group">
            <h3 class="modal__group-title">Dates</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>before:2026-01-01</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Created before a date (YYYY-MM-DD, all types)
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>after:2026-01-01</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Created on/after a date (YYYY-MM-DD, all types) - for todo deadlines use <code>due:today</code> / <code>due:week</code> instead
                    </dd>
                </div>
            </dl>
        </div>

        <div class="modal__group">
            <h3 class="modal__group-title">Sorting &amp; text</h3>
            <dl class="modal__list">
                <div class="modal__row">
                    <dt class="modal__row-term">
                        <code>sort:title</code> / <code>sort:created</code> / <code>sort:updated</code>
                    </dt>
                    <dd class="modal__row-desc">
                        Default: last updated
                    </dd>
                </div>
                <div class="modal__row">
                    <dt class="modal__row-term">Any other words</dt>
                    <dd class="modal__row-desc">
                        Matched against title &amp; content
                    </dd>
                </div>
            </dl>
        </div>
    </dialog>

    <form method="get"
          class="filters"
          role="search"
          hx-get="{{ url_for('search.search_view') }}"
          hx-trigger="input changed from:find input, submit"
          hx-select="#search-results"
          hx-target="#search-results"
          hx-swap="outerHTML"
          hx-replace-url="true">
        <label for="q" class="visually-hidden">Search</label>
        <input type="search"
               id="q"
               name="q"
               class="field__input filters__input"
               placeholder="is:todo state:open group:home overdue:yes due:week sort:title ..."
               value="{{ query }}"
               autocomplete="off"
               autofocus />
        <button type="submit" class="button">{{ icon("search") }} Search</button>
    </form>

    <div id="search-results">
        {% if not query %}
            {{ empty_state('search', 'Try is:todo, is:note, is:sticky, state:open, group:home, archived:yes, pinned:yes, overdue:yes, due:today, due:week, before:2026-01-01, after:2026-01-01, sort:title, sort:created, colour:pink') }}
        {% elif results %}
            <ul class="card-list">
                {% for result in results %}
                    <li>
                        <article class="entry-card">
                            <h3 class="entry-card__title">
                                <a href="{{ url_for(result.endpoint, **result.url_kwargs) }}"
                                   class="entry-card__link">
                                    <span class="entry-card__title-text">{{ result.title }}</span>
                                    <span class="entry-card__badges">
                                        <span class="badge badge--{{ result.kind }}">{{ icon(result.kind) }} {{ result.kind | capitalize }}</span>
                                        {% if result.kind == "todo" %}
                                            <span class="badge{% if result.state=='open' %} badge--open{% elif result.state=='active' %} badge--active{% elif result.state=='done' %} badge--done{% elif result.state=='cancelled' %} badge--cancelled{% endif %}">{{ result.state | replace('_', ' ') | title }}</span>
                                            {% if result.overdue %}<span class="badge badge--overdue">Overdue</span>{% endif %}
                                        {% endif %}
                                        {% if result.kind in ("note", "todo") and result.archived %}<span class="badge">{{ icon("archive") }} Archived</span>{% endif %}
                                        {% if result.kind == "sticky" and result.pinned %}<span class="badge">{{ icon("pin") }} Pinned</span>{% endif %}
                                        {% if result.get("group_name") %}<span class="badge">{{ icon("folder") }} {{ result.group_name }}</span>{% endif %}
                                    </span>
                                </a>
                            </h3>
                            <p class="entry-card__timestamp">
                                <time datetime="{{ result.updated_at | isoformat(local=False) }}" data-live>{{ result.updated_at | timeago(local=False) }}</time>
                                ({{ result.updated_at | strftime("%d %b %Y, %H:%M", local=False) }})
                            </p>
                            {% if result.snippet %}<p class="entry-card__preview">{{ result.snippet }}</p>{% endif %}
                        </article>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            {{ empty_state("search", 'No results for "' + query + '".') }}
        {% endif %}
    </div>
{% endblock %}
