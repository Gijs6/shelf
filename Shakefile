#!/bin/bash

setup() {
  python3 -m venv .venv
  .venv/bin/pip install -r requirements.txt
  npm install
  mkdir -p static/vendor
  cp node_modules/htmx.org/dist/htmx.min.js static/vendor/htmx.min.js
  cp node_modules/easymde/dist/easymde.min.js static/vendor/easymde.min.js
  cp node_modules/easymde/dist/easymde.min.css static/vendor/easymde.min.css
}

serve() {
  .venv/bin/python app.py
}

seed() {
  .venv/bin/python seed.py "$@"
}

build() {
  npm run build:css
}

deploy() {
  build
  echo "$(date +%Y.%m):$(git rev-parse --short HEAD):$(git rev-list --count HEAD)" > VERSION
  shake_super deploy
}
